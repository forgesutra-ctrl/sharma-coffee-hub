# Supabase (required for auth and data)
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Razorpay (required for payments; key is also used in Edge Function secrets)
# Get from: Razorpay Dashboard > API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Prozo Proship — signin at POST /api/auth/signin (VITE_ prefix required in browser)
VITE_PROZO_USERNAME=
VITE_PROZO_PASSWORD=
VITE_PROZO_BASE_URL=https://proshipdev.prozo.com

# Warehouse / pickup details for Prozo create order
VITE_STORE_NAME=
VITE_STORE_PHONE=
VITE_STORE_EMAIL=
VITE_STORE_ADDRESS=
VITE_STORE_CITY=
VITE_STORE_STATE=
VITE_STORE_PINCODE=

# DTDC Shipping API â€” backend-only (no VITE_ prefix; used by Supabase Edge Functions only)
# Get these from your DTDC account manager
DTDC_API_KEY=
DTDC_CUSTOMER_CODE=
DTDC_ACCESS_TOKEN=
DTDC_TRACKING_USERNAME=
DTDC_TRACKING_PASSWORD=
# Use staging URLs for testing, production URLs for live
DTDC_API_BASE_URL=https://alphademodashboardapi.shipsy.io
DTDC_TRACKING_BASE_URL=http://dtdcstagingapi.dtdc.com/dtdc-tracking-api