# Supabase (required for auth and data)
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Razorpay (required for payments; key is also used in Edge Function secrets)
# Get from: Razorpay Dashboard > API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# DTDC Shipping API — backend-only (no VITE_ prefix; used by Supabase Edge Functions only)
# Get these from your DTDC account manager
# Pickup/warehouse STORE_* vars (STORE_NAME, STORE_PHONE, STORE_EMAIL, STORE_ADDRESS,
# STORE_CITY, STORE_STATE, STORE_PINCODE) are Supabase Edge Function secrets, not browser-side VITE_ vars.
DTDC_API_KEY=
DTDC_CUSTOMER_CODE=
DTDC_ACCESS_TOKEN=
DTDC_TRACKING_USERNAME=
DTDC_TRACKING_PASSWORD=
# Use staging URLs for testing, production URLs for live
DTDC_API_BASE_URL=https://alphademodashboardapi.shipsy.io
DTDC_TRACKING_BASE_URL=http://dtdcstagingapi.dtdc.com/dtdc-tracking-api